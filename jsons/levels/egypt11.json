        {
            "Character": "crazydave",
            "Action": "SAY",
            "Lines": {
                "en": "Hmm... it's pretty silent right now... ",
                "zh": "Hmm... it's pretty silent right now... "
            }
        },
        {
            "Character": "zombossicon",
            "Action": "NPC_ENTER"
        },
        {
            "Character": "zombossicon",
            "Action": "EXCITED",
            "Lines": {
                "en": "Hello losers! ",
                "zh": "Hello losers! "
            }
        },
        {
            "Character": "winnie",
            "Action": "TIRED",
            "Lines": {
                "en": "And that's why it was quiet... ",
                "zh": "And that's why it was quiet... "
            }
        },
        {
            "Character": "zombossicon",
            "Action": "PLAYFUL",
            "Lines": {
                "en": "Hey, turn that frown upside down, I'll make a tasty meal out of your brains! ",
                "zh": "Hey, turn that frown upside down, I'll make a tasty meal out of your brains! "
            }
        },
        {
            "Character": "winnie",
            "Action": "TIRED",
            "Lines": {
                "en": "Could you just stop talking. ",
                "zh": "Could you just stop talking. "
            }
        },
        {
            "Character": "crazydave",
            "Action": "SAY",
            "Lines": {
                "en": "What are you doing here! And why have you brought us here! ",
                "zh": "What are you doing here! And why have you brought us here! "
            }
        },
        {
            "Character": "zombossicon",
            "Action": "EXCITED",
            "Lines": {
                "en": "Is it not obvious? I am simply going to defeat you! ",
                "zh": "Is it not obvious? I am simply going to defeat you! "
            }
        },
        {
            "Character": "crazydave",
            "Action": "TIRED",
            "Lines": {
                "en": "But why ancient      egypt...? ",
                "zh": "But why ancient      egypt...? "
            }
        },
        {
            "Character": "zombossicon",
            "Action": "EXCITED",
            "Lines": {
                "en": "Well obviously, I needed some good scenery to go with the taste of your defeat! ",
                "zh": "Well obviously, I needed some good scenery to go with the taste of your defeat! "
            }
        },
        {
            "Character": "zombossicon",
            "Action": "EXCITED",
            "Lines": {
                "en": "Well it was fun, but time to kill you now! ",
                "zh": "Well it was fun, but time to kill you now! "
            }
        },
        {
            "Character": "zombossicon",
            "Action": "NPC_EXIT"
        },
        {
            "Character": "winnie",
            "Action": "TIRED",
            "Lines": {
                "en": "I hope we do not see him again ever after this. ",
                "zh": "I hope we do not see him again ever after this. "
            }
        }
    ]
    }
